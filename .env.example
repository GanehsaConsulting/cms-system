# =============================================================================
# CMS System — environment template (safe to commit)
# Copy to .env and fill in real values. Never commit .env.
# =============================================================================

# App
NODE_ENV=development
NEXT_PUBLIC_APP_URL=http://localhost:3000

# PostgreSQL
# postgresql://USER:PASSWORD@HOST:PORT/DATABASE
# Filess.io often locks CREATE on public — use owned schema `cms`.
DATABASE_URL=
DB_SCHEMA=cms

# Auth — generate with: openssl rand -base64 48
AUTH_SECRET=
BETTER_AUTH_SECRET=
BETTER_AUTH_URL=http://localhost:3000

# Session policy (seconds) — 8h max / 1h sliding refresh default
AUTH_SESSION_MAX_AGE=28800
AUTH_SESSION_UPDATE_AGE=3600

# Cloudinary
# cloudinary://API_KEY:API_SECRET@CLOUD_NAME
CLOUDINARY_URL=
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Cron (cron-job.org) — publish due scheduled articles
# Generate with: openssl rand -base64 32
CRON_SECRET=

# Public API — preview draft/scheduled articles on staging FE
# Query: ?preview=SECRET or Authorization: Bearer SECRET on GET /api/public/articles/{slug}
# Generate with: openssl rand -base64 32
CMS_PREVIEW_SECRET=
